rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers -------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Guest (anonymous) sign-in uses localStorage only in the app; block Firestore for them.
    function isPersistedAccount() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Validates the single app document shape written by saveToFirestore().
    function isValidAppData() {
      return request.resource.data.keys().hasAll([
          'expenses',
          'customCategories',
          'budgetsByMonth',
          'subBudgetsByMonth',
        ])
        && request.resource.data.expenses is list
        && request.resource.data.customCategories is list
        && request.resource.data.budgetsByMonth is map
        && request.resource.data.subBudgetsByMonth is map;
    }

    // --- User data: users/{uid}/data/app -------------------------------------

    match /users/{userId} {
      // No direct reads/writes on the user root document (app uses subcollection only).
      allow read, write: if false;

      match /data/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();

        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'app'
          && isValidAppData();

        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'app';
      }
    }

    // All other paths are denied by default.
  }
}
