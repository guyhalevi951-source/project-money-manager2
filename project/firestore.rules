rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPersistedAccount() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isValidIsoCurrencyCode(code) {
      return code.matches('^[A-Z]{3}$');
    }

    function isValidExpensesDoc() {
      return request.resource.data.keys().hasAll(['expenses'])
        && request.resource.data.expenses is list;
    }

    function isValidCategoriesDoc() {
      return request.resource.data.keys().hasAll([
          'customCategories',
          'budgetsByMonth',
          'subBudgetsByMonth',
        ])
        && request.resource.data.customCategories is list
        && request.resource.data.budgetsByMonth is map
        && request.resource.data.subBudgetsByMonth is map;
    }

    function isValidSettingsDoc() {
      return request.resource.data.keys().hasAll([
          'lang',
          'keepOriginalValues',
          'displayCurrency',
          'saved_colors',
          'custom_currencies',
        ])
        && request.resource.data.lang in ['he', 'en']
        && request.resource.data.keepOriginalValues is bool
        && isValidIsoCurrencyCode(request.resource.data.displayCurrency)
        && request.resource.data.saved_colors is list
        && request.resource.data.custom_currencies is list
        && request.resource.data.custom_currencies.size() <= 20;
    }

    function isValidLegacyAppData() {
      return request.resource.data.keys().hasAll([
          'expenses',
          'customCategories',
          'budgetsByMonth',
          'subBudgetsByMonth',
        ])
        && request.resource.data.expenses is list
        && request.resource.data.customCategories is list
        && request.resource.data.budgetsByMonth is map
        && request.resource.data.subBudgetsByMonth is map;
    }

    function isValidManualOverridesDoc() {
      return request.resource.data.keys().hasAll(['overrides'])
        && request.resource.data.overrides is map;
    }

    function isValidCurrencyCommissionsDoc() {
      return request.resource.data.keys().hasAll(['commissions'])
        && request.resource.data.commissions is map;
    }

    match /users/{userId} {
      allow read, write: if false;

      match /expenses/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();
        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'data'
          && isValidExpensesDoc();
        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'data';
      }

      match /categories/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();
        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'data'
          && isValidCategoriesDoc();
        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'data';
      }

      match /settings/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();
        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'data'
          && isValidSettingsDoc();
        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'data';
      }

      match /manual_exchange_overrides/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();
        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'data'
          && isValidManualOverridesDoc();
        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'data';
      }

      match /currency_commissions/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();
        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'data'
          && isValidCurrencyCommissionsDoc();
        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'data';
      }

      match /data/{docId} {
        allow read: if isOwner(userId) && isPersistedAccount();
        allow create, update: if isOwner(userId)
          && isPersistedAccount()
          && docId == 'app'
          && isValidLegacyAppData();
        allow delete: if isOwner(userId) && isPersistedAccount() && docId == 'app';
      }
    }
  }
}
